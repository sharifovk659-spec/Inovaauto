# Supabase — скопируйте в .env

IA_SUPABASE_URL=https://xenelqfppvjyuxnoamme.supabase.co
IA_SUPABASE_PROJECT_REF=xenelqfppvjyuxnoamme

IA_DB_POOLER_HOST=aws-1-ap-southeast-1.pooler.supabase.com
IA_DB_POOLER_PORT=6543
IA_DB_POOLER_USER=postgres.xenelqfppvjyuxnoamme

IA_DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
IA_DB_PORT=6543
IA_DB_NAME=postgres
IA_DB_USER=postgres.xenelqfppvjyuxnoamme
IA_SUPABASE_DB_PASSWORD=YOUR_PASSWORD

# @ в пароле → %40 в URL
DATABASE_URL=postgresql://postgres.xenelqfppvjyuxnoamme:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=prefer
IA_DATABASE_URL=postgresql://postgres.xenelqfppvjyuxnoamme:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=prefer

IA_DB_DRIVER=pgsql
# Hostinger (без pdo_pgsql): IA_DB_DRIVER=supabase + sql/supabase_rpc_proxy.sql
IA_DB_SSLMODE=prefer
IA_DB_AUTO_ENSURE=false
IA_DB_PLATFORM_SCHEMA=false
IA_DB_SEED_ADMIN=false
IA_DB_CONNECT_TIMEOUT=8
IA_SEED_PLATFORM_DEMO=false
IA_SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
IA_SUPABASE_STORAGE_BUCKET=photos
IA_SUPABASE_STORAGE_ENABLED=true

# Холӣ гузоред — дар localhost автоматӣ аз папкаи лоиҳа муайян мешавад
IA_BASE_URL=
IA_DETECT_BASE_URL=true

# Cloudflare / production (inovaauto.com — бе www)
IA_CANONICAL_HOST=inovaauto.com
IA_FORCE_HTTPS=auto
IA_HSTS=true
IA_TRUST_CLOUDFLARE=auto
IA_SESSION_SECURE=false

# Assets: false = .min.css / .min.js on site; true = unminified sources (local edits)
IA_CSS_DEV=false
IA_JS_DEV=false

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: https://YOUR-DOMAIN/google-auth-callback.php
IA_GOOGLE_CLIENT_ID=
IA_GOOGLE_CLIENT_SECRET=
