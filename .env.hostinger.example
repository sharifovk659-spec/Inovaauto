# Hostinger inovaauto.com — MySQL + Supabase Storage

IA_BASE_URL=https://inovaauto.com
IA_CANONICAL_HOST=inovaauto.com
IA_DETECT_BASE_URL=true
IA_FORCE_HTTPS=auto
IA_HSTS=true
IA_TRUST_CLOUDFLARE=auto
IA_SESSION_SECURE=true

# --- MySQL (hPanel → Databases) ---
IA_DB_DRIVER=mysql
IA_DB_HOST=localhost
IA_DB_PORT=3306
IA_DB_NAME=u417315406_innovaauto
IA_DB_USER=u417315406_admin
IA_DB_PASS=YOUR_MYSQL_PASSWORD

IA_DB_AUTO_ENSURE=true
IA_DB_PLATFORM_SCHEMA=true
IA_DB_SEED_ADMIN=true
IA_SEED_PLATFORM_DEMO=false

# --- Supabase: фото + миграция данных ---
IA_SUPABASE_URL=https://xenelqfppvjyuxnoamme.supabase.co
IA_SUPABASE_PROJECT_REF=xenelqfppvjyuxnoamme
IA_SUPABASE_SECRET_KEY=YOUR_SUPABASE_SERVICE_KEY
IA_SUPABASE_STORAGE_BUCKET=photos
IA_SUPABASE_STORAGE_ENABLED=true

IA_MIGRATE_TOKEN=innova2026migrate

# Google OAuth — redirect: https://inovaauto.com/google-auth-callback.php
IA_GOOGLE_CLIENT_ID=
